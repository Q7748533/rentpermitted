---
// City page layout
export interface Props {
  city: string;
  state: string;
  stateAbbr: string;
  status: 'allowed' | 'restricted' | 'banned';
  lastUpdated: string;
}
const { city, state, stateAbbr, status, lastUpdated } = Astro.props;
const statusLabel = { allowed: 'Allowed with Regulations', restricted: 'Heavily Restricted', banned: 'Effectively Banned' };
const statusColor = { allowed: '#16a34a', restricted: '#ca8a04', banned: '#dc2626' };
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{city} Short-Term Rental Regulations — Permits, Taxes & Rules (2026)</title>
  <meta name="description" content={`Complete guide to ${city}, ${stateAbbr} short-term rental laws: permits, taxes, zoning, and compliance requirements for Airbnb & Vrbo hosts. Updated ${lastUpdated}.`} />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo">RentPermitted</a>
    <nav>
      <a href="/states/">Browse by State</a>
      <a href="/cities/">All Cities</a>
      <a href="/tools/">Tools</a>
    </nav>
  </header>

  <main class="city-page">
    <!-- Status Badge -->
    <div class="status-badge" style="background:{statusColor[status]};color:white">
      {statusLabel[status]}
    </div>

    <!-- Hero -->
    <h1>{city}, {stateAbbr} Short-Term Rental Regulations</h1>
    <p class="subtitle">Everything you need to know about operating an Airbnb, Vrbo, or vacation rental in {city}. Permit requirements, tax obligations, and zoning rules — updated {lastUpdated}.</p>

    <!-- Quick Facts -->
    <section class="quick-facts">
      <h2>At a Glance</h2>
      <div class="facts-grid">
        <div class="fact">
          <span class="fact-label">STR Status</span>
          <span class="fact-value">{statusLabel[status]}</span>
        </div>
        <div class="fact">
          <span class="fact-label">Permit Required</span>
          <span class="fact-value"><slot name="permitRequired" /></span>
        </div>
        <div class="fact">
          <span class="fact-label">License Fee</span>
          <span class="fact-value"><slot name="licenseFee" /></span>
        </div>
        <div class="fact">
          <span class="fact-label">Occupancy Tax</span>
          <span class="fact-value"><slot name="occupancyTax" /></span>
        </div>
        <div class="fact">
          <span class="fact-label">Nights Cap</span>
          <span class="fact-value"><slot name="nightsCap" /></span>
        </div>
        <div class="fact">
          <span class="fact-label">Last Verified</span>
          <span class="fact-value">{lastUpdated}</span>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <article>
      <slot />
    </article>

    <!-- Disclaimer -->
    <div class="disclaimer">
      <strong>Disclaimer:</strong> This information is for reference only and does not constitute legal advice. Regulations change frequently. Always verify with the <slot name="officialLink" /> before listing your property.
    </div>
  </main>

  <footer>
    <p>RentPermitted — Independent short-term rental regulation resource. Not affiliated with any government agency.</p>
    <p><a href="/affiliate-disclosure/">Affiliate Disclosure</a> · <a href="/privacy/">Privacy Policy</a> · <a href="/contact/">Contact</a></p>
  </footer>
</body>
</html>

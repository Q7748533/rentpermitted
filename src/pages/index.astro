---
import cities from '../data/cities.json';

const tier1 = cities.cities.filter(c => c.tier === 1);
const states = [...new Set(cities.cities.map(c => c.state))].sort();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RentPermitted — Short-Term Rental Regulations for Every US City</title>
  <meta name="description" content="Find up-to-date short-term rental laws, permits, taxes, and compliance guides for Airbnb and Vrbo hosts across US cities. Independent, accurate, and always current." />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo">RentPermitted</a>
    <nav>
      <a href="/#cities">Browse Cities</a>
      <a href="/#states">By State</a>
      <a href="/about/">About</a>
    </nav>
  </header>

  <main style="max-width:900px;margin:0 auto;padding:0 1rem;">
    <!-- Hero -->
    <section style="text-align:center;padding:4rem 0 3rem;">
      <h1 style="font-size:2.5rem;margin-bottom:0.75rem;">Is Your Short-Term Rental <span style="color:var(--green)">Permitted</span>?</h1>
      <p style="font-size:1.2rem;color:#666;max-width:600px;margin:0 auto 2rem;">
        Find current regulations, permit requirements, taxes, and compliance rules for Airbnb and Vrbo hosts in every major US city.
      </p>
      <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
        <a href="#cities" style="background:var(--accent);color:white;padding:0.75rem 1.5rem;border-radius:6px;text-decoration:none;font-weight:600;">Browse Cities</a>
        <a href="#states" style="background:white;color:var(--accent);padding:0.75rem 1.5rem;border-radius:6px;text-decoration:none;font-weight:600;border:1px solid var(--accent);">By State</a>
      </div>
    </section>

    <!-- Stats -->
    <section style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;text-align:center;padding:1.5rem;background:white;border:1px solid var(--border);border-radius:8px;margin-bottom:3rem;">
      <div><strong style="display:block;font-size:1.5rem;color:var(--accent);">{cities.cities.length}</strong><span style="font-size:0.9rem;color:#666;">Cities Covered</span></div>
      <div><strong style="display:block;font-size:1.5rem;color:var(--accent);">{states.length}</strong><span style="font-size:0.9rem;color:#666;">States</span></div>
      <div><strong style="display:block;font-size:1.5rem;color:var(--accent);">2026</strong><span style="font-size:0.9rem;color:#666;">Updated</span></div>
    </section>

    <!-- City Grid -->
    <h2 id="cities" style="font-size:1.5rem;margin-bottom:1rem;">Browse by City</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;margin-bottom:3rem;">
      {tier1.map((c) => (
        <a href={`/${c.slug}/`} style="display:block;padding:1rem;background:white;border:1px solid var(--border);border-radius:6px;text-decoration:none;color:var(--text);transition:border-color 0.2s;">
          <strong>{c.name}</strong>
          <span style="display:block;color:#666;font-size:0.85rem;">{c.abbr}</span>
        </a>
      ))}
    </div>

    <!-- By State -->
    <h2 id="states" style="font-size:1.5rem;margin-bottom:1rem;">Browse by State</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:0.5rem;margin-bottom:2rem;">
      {states.map((s) => {
        const count = cities.cities.filter(c => c.state === s).length;
        return (
          <span style="display:block;padding:0.5rem 0.75rem;background:white;border:1px solid var(--border);border-radius:4px;font-size:0.9rem;">
            {s} <span style="color:#999;">({count})</span>
          </span>
        );
      })}
    </div>

    <!-- Disclaimer -->
    <div class="disclaimer">
      <strong>Disclaimer:</strong> RentPermitted is an independent information resource. We are not a government agency and do not issue permits or licenses. All information is for reference only. Always verify with your local government before listing your property. <a href="/affiliate-disclosure/">Affiliate Disclosure</a>.
    </div>
  </main>

  <footer>
    <p>RentPermitted — Short-term rental regulations, made clear. Not affiliated with any government agency.</p>
    <p><a href="/affiliate-disclosure/">Affiliate Disclosure</a> · <a href="/privacy/">Privacy Policy</a> · <a href="/contact/">Contact</a></p>
  </footer>
</body>
</html>
